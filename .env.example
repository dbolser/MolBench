# MolBench API keys — copy this file to `.env` and fill in only what you need:
#
#     cp .env.example .env
#
# `.env` is gitignored. NEVER commit real keys. The runner auto-loads `.env`
# from the repo root (already-exported shell vars take precedence).
# You only need keys for the providers you actually benchmark.

# --- Anthropic ------------------------------------------------------------------
# spec: anthropic:<model-id>   e.g.  anthropic:claude-opus-4-8
# install: pip install -e ".[anthropic]"
ANTHROPIC_API_KEY=

# --- OpenAI ---------------------------------------------------------------------
# spec: openai:<model-id>      e.g.  openai:gpt-4o
# install: pip install -e ".[openai]"
OPENAI_API_KEY=

# Optional: point the OpenAI adapter at ANY OpenAI-compatible endpoint
# (Together, Groq, DeepInfra, or a local Ollama/vLLM server). Then still use the
# openai:<id> spec, e.g.  openai:llama3.1  with a local server.
#   OPENAI_BASE_URL=http://localhost:11434/v1     # Ollama
#   OPENAI_BASE_URL=https://api.together.xyz/v1   # Together
# OPENAI_BASE_URL=

# --- Google Gemini (via OpenAI-compatibility layer) -----------------------------
# Uses Google's OpenAI-compatible endpoint, so the same OpenAI SDK works.
# Get a key at https://aistudio.google.com/apikey
# spec: gemini:<model-id>   e.g.  gemini:gemini-3.5-flash , gemini:gemini-2.5-flash
# install: pip install -e ".[openai]"
GEMINI_API_KEY=

# --- OpenRouter -----------------------------------------------------------------
# One key, hundreds of open + closed models. Uses the OpenAI SDK under the hood.
# spec: openrouter:<vendor>/<model-id>
#   e.g.  openrouter:qwen/qwen-2.5-72b-instruct
#         openrouter:meta-llama/llama-3.3-70b-instruct
#         openrouter:anthropic/claude-3.5-haiku
# install: pip install -e ".[openai]"
OPENROUTER_API_KEY=
