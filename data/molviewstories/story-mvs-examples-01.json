{
  "id": "story-mvs-examples-01",
  "kind": "scene",
  "source": "molviewstories",
  "story": "mvs-examples",
  "title": "Labels and Focus",
  "caption": "Labels and Focus. Custom Labels A molecule (PDB ID 1lap) visualization with custom labels and focused residue highlighting.",
  "scene_mvs": {
    "kind": "root",
    "children": [
      {
        "kind": "download",
        "params": {
          "url": "https://www.ebi.ac.uk/pdbe/entry-files/download/1lap_updated.cif"
        },
        "children": [
          {
            "kind": "parse",
            "params": {
              "format": "mmcif"
            },
            "children": [
              {
                "kind": "structure",
                "params": {
                  "type": "model"
                },
                "children": [
                  {
                    "kind": "component",
                    "params": {
                      "selector": "all"
                    },
                    "children": [
                      {
                        "kind": "representation",
                        "params": {
                          "type": "cartoon"
                        },
                        "children": [
                          {
                            "kind": "color",
                            "params": {
                              "color": "red",
                              "selector": {
                                "label_asym_id": "A",
                                "label_seq_id": 120
                              }
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "kind": "component",
                    "params": {
                      "selector": {
                        "label_asym_id": "A",
                        "label_seq_id": 120
                      }
                    },
                    "children": [
                      {
                        "kind": "label",
                        "params": {
                          "text": "ALA 120 A: My Label"
                        }
                      },
                      {
                        "kind": "focus",
                        "params": {}
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "categories": [
    "load",
    "selection",
    "representation",
    "color",
    "camera",
    "multi-component",
    "annotation"
  ]
}