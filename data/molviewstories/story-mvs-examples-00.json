{
  "id": "story-mvs-examples-00",
  "kind": "scene",
  "source": "molviewstories",
  "story": "mvs-examples",
  "title": "Basic Visualization",
  "caption": "Basic Visualization. Basic Molecular Visualization Load a molecule from URL (PDB ID 1cbs) and display default representation (cartoon) in blue color.",
  "scene_mvs": {
    "kind": "root",
    "children": [
      {
        "kind": "download",
        "params": {
          "url": "https://www.ebi.ac.uk/pdbe/entry-files/download/1cbs_updated.cif"
        },
        "children": [
          {
            "kind": "parse",
            "params": {
              "format": "mmcif"
            },
            "children": [
              {
                "kind": "structure",
                "params": {
                  "type": "model"
                },
                "children": [
                  {
                    "kind": "component",
                    "params": {
                      "selector": "all"
                    },
                    "children": [
                      {
                        "kind": "representation",
                        "params": {
                          "type": "cartoon"
                        },
                        "children": [
                          {
                            "kind": "color",
                            "params": {
                              "color": "blue"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "categories": [
    "load",
    "representation",
    "color"
  ]
}